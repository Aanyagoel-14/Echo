# Dependencies
node_modules/

# Build output
dist/

# Local env files
.env
.env.local
.env.*.local

# Local-only test fixtures — real personal social exports used to test the
# importer (Instagram posts_1.json / X tweets.js / LinkedIn Shares.csv). They
# contain personal data and must never be committed or shipped. Force-add with
# `git add -f` if you ever want a synthetic fixture in the repo.
test/fixtures/

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Instagram worker — local scrape output + saved Instaloader sessions. The
# shared, app-read file is data/instagram-cooccurrence.json (committed by CI).
worker/output/
worker/*.session
worker/*.session-*

# Python artifacts (the worker is the only Python in the repo)
__pycache__/
*.pyc

# Claude Code local settings
.claude/

# Vercel
.vercel
