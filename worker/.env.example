# Echo Instagram co-occurrence worker — config. Copy to worker/.env and fill in.
# All values are optional, but Instagram heavily limits anonymous hashtag access,
# so an authenticated session (or username/password) is strongly recommended.

# Authenticated session (preferred). Point IG_SESSIONFILE at a session saved by
# `instaloader --login <user>` and set IG_USERNAME to the same handle.
IG_USERNAME=
IG_SESSIONFILE=

# Fallback auth: username/password (IG_USERNAME above + this). A saved session
# is safer and avoids repeated logins (which trip Instagram's checkpoints).
IG_PASSWORD=

# Route requests through a (rotating) proxy. Instaloader uses `requests`, which
# honours this standard env var. For real rotation, point it at a rotating-proxy
# endpoint.
HTTPS_PROXY=

# Where to write the output the Node harvest reads. The GitHub Action sets this
# to data/instagram-cooccurrence.json (the path fetchInstagramCooccurrence reads).
ECHO_IG_OUTPUT=worker/output/instagram-cooccurrence.json

# Tuning (defaults shown). Keep these modest — Instagram rate-limits hard.
IG_POSTS_PER_TAG=15
IG_MAX_TAGS_PER_NICHE=8
IG_MAX_SEEDS_PER_NICHE=3
IG_SLEEP_SECONDS=2
IG_GEO=US
